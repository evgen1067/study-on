{% extends 'base.html.twig' %}

{% block title %}Lesson{% endblock %}

{% block body %}
    <div class="container">
        <h3>{{ lesson.name }}</h3>

        <h5 class="fw-normal">{{ lesson.content }}</h5>

        <div class="d-flex flex-column">
            <a class="btn btn-primary mb-3" href="{{ path('app_course_show', { 'id': lesson.course.id }) }}">К курсу</a>

            <a class="btn btn-warning mb-3" href="{{ path('app_lesson_edit', {'id': lesson.id}) }}">Редактировать</a>

            {{ include('lesson/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
